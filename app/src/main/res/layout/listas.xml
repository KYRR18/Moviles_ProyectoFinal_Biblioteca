<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F1EA"
    tools:context="ListasActivity">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:background="#7D5A44"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/flecha_left"
            app:tint="#F5F1EA"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lista"
            android:textColor="#F5F1EA"
            android:textSize="24sp"
            android:fontFamily="serif"
            android:paddingStart="15dp"/>

        <ImageView
            android:id="@+id/btnRefresh"
            android:layout_width="29dp"
            android:layout_height="29dp"
            android:layout_marginEnd="15dp"
            android:src="@drawable/refresh"
            app:tint="#F5F1EA" />

        <ImageView
            android:visibility="gone"
            android:id="@+id/btnMoreOptions"
            android:layout_width="29dp"
            android:layout_height="29dp"
            android:src="@drawable/puntos"
            app:tint="#F5F1EA"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvHeaderFiles"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Files"
        android:textColor="#4A342A"
        android:textSize="18sp"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFiles"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderFiles"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_lista" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="75dp"
        android:background="#7D5A44"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/navHome"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginHorizontal="24dp"
            android:src="@drawable/home"
            app:tint="#D7C9B8"/>

        <ImageView
            android:id="@+id/navLista"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginHorizontal="24dp"
            android:src="@drawable/lista"
            app:tint="#F5F1EA"/>

        <ImageView
            android:id="@+id/navBuscar"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginHorizontal="24dp"
            android:src="@drawable/lupa"
            app:tint="#D7C9B8"/>

        <ImageView
            android:id="@+id/navUser"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginHorizontal="24dp"
            android:src="@drawable/perfil"
            app:tint="#D7C9B8"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>