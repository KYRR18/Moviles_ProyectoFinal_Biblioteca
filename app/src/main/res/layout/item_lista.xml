<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:background="@android:color/transparent">

    <ImageView
        android:id="@+id/imgIconFile"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/lista"
        app:tint="#4A342A"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tvItemTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Libro cósmico"
            android:textColor="#4A342A"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="serif"/>

        <TextView
            android:id="@+id/tvModifiedDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modified 14:05"
            android:textColor="#7D5A44"
            android:textSize="14sp"
            android:textStyle="italic"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatusValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3"
        android:textColor="#4A342A"
        android:textSize="18sp"
        android:fontFamily="serif"/>

</LinearLayout>