<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F1EA"
    tools:context=".ModificarLibroActivity">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0sp"
        android:layout_height="70sp"
        android:background="#7D5A44"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40sp"
            android:layout_height="40sp"
            android:src="@drawable/flecha_left"
            app:tint="#F5F1EA"/>

        <TextView
            android:layout_width="0sp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_modificar"
            android:textColor="#F5F1EA"
            android:textSize="28sp"
            android:fontFamily="serif"
            android:paddingStart="15sp"/>

        <ImageView
            android:id="@+id/btnDeleteBook"
            android:layout_width="48sp"
            android:layout_height="48sp"
            android:layout_marginEnd="16sp"
            android:src="@drawable/delete"
            app:tint="#F5F1EA" />

        <ImageView
            android:visibility="gone"
            android:id="@+id/btnMoreOptions"
            android:layout_width="28sp"
            android:layout_height="28sp"
            android:src="@drawable/puntos"
            app:tint="#F5F1EA" />
    </LinearLayout>

    <ScrollView
        android:layout_width="0sp"
        android:layout_height="0sp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24sp"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/imgBookPreview"
                android:layout_width="120sp"
                android:layout_height="120sp"
                android:layout_marginTop="10sp"
                android:layout_marginBottom="30sp"
                android:src="@drawable/lista"
                app:tint="#4A342A" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Título"
                android:layout_marginBottom="16sp"
                app:boxStrokeColor="#7D5A44"
                app:hintTextColor="#7D5A44"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTitleMod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#4A342A"
                    android:inputType="textCapSentences" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Autor"
                android:layout_marginBottom="16sp"
                app:boxStrokeColor="#7D5A44"
                app:hintTextColor="#7D5A44"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAuthorMod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#4A342A"
                    android:inputType="textPersonName" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Editorial"
                android:layout_marginBottom="16sp"
                app:boxStrokeColor="#7D5A44"
                app:hintTextColor="#7D5A44"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPublisherMod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#4A342A"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="ISBN"
                android:layout_marginBottom="30sp"
                app:boxStrokeColor="#4A342A"
                app:hintTextColor="#4A342A"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etIsbnMod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#4A342A"
                    android:inputType="number"
                    android:focusable="false"
                    android:cursorVisible="false"
                    />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelMod"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0sp"
                    android:layout_height="55sp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8sp"
                    android:text="Cancel"
                    android:textColor="#7D5A44"
                    android:textAllCaps="false"
                    app:strokeColor="#B2967D"
                    app:cornerRadius="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmMod"
                    android:layout_width="0sp"
                    android:layout_height="55sp"
                    android:layout_weight="1"
                    android:layout_marginStart="8sp"
                    android:text="Confirmar"
                    android:backgroundTint="#4A342A"
                    android:textColor="#F5F1EA"
                    android:textAllCaps="false"
                    app:cornerRadius="12sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0sp"
        android:layout_height="75sp"
        android:background="#7D5A44"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_homeMod"
            android:layout_width="34sp" android:layout_height="34sp" android:layout_marginHorizontal="24sp" android:src="@drawable/home" app:tint="#F5F1EA"/>
        <ImageView android:id="@+id/iv_listMod" android:layout_width="34sp" android:layout_height="34sp" android:layout_marginHorizontal="24sp" android:src="@drawable/lista" app:tint="#F5F1EA"/>
        <ImageView android:id="@+id/iv_searchMod" android:layout_width="34sp" android:layout_height="34sp" android:layout_marginHorizontal="24sp" android:src="@drawable/lupa" app:tint="#F5F1EA"/>
        <ImageView android:id="@+id/iv_userMod" android:layout_width="34sp" android:layout_height="34sp" android:layout_marginHorizontal="24sp" android:src="@drawable/perfil" app:tint="#F5F1EA"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>