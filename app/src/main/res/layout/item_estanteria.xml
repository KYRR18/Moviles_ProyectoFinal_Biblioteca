<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingVertical="8dp">

    <!-- Título de la estantería -->
    <TextView
        android:id="@+id/tvTituloEstanteria"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Estantería"
        android:textSize="20sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:textColor="#4A342A"
        android:layout_marginBottom="8dp"/>

    <!-- Card de la estantería -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="180dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#D7C9B8">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Tus libros aparecerán aquí"
                android:fontFamily="sans-serif-medium"
                android:textColor="#7D5A44"/>

            <!-- FAB para agregar un libro a esta estantería -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAddLibro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:contentDescription="Añadir libro a estantería"
                app:backgroundTint="#4A342A"
                app:srcCompat="@android:drawable/ic_input_add"
                app:tint="#F5F1EA"
                app:fabSize="mini" />

        </FrameLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
