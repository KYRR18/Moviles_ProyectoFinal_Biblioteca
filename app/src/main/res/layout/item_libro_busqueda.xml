<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/khaki"
    app:strokeWidth="1dp"
    app:strokeColor="@color/camel">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutLibro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">


        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgPortadaItem"
            android:layout_width="60dp"
            android:layout_height="90dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:background="@color/camel"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/RoundedImageView" />

        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="220sp"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/tvGenerosItem"
            android:layout_toEndOf="@id/imgPortadaItem"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@+id/imgPortadaItem"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvTituloItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Título"
                android:textColor="@color/espresso"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAutorItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Autor"
                android:textColor="@color/cocoa"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvGenerosItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignBottom="@id/imgPortadaItem"
            android:layout_alignParentEnd="true"
            android:fontFamily="serif"
            android:layout_marginStart="30sp"
            android:text="Almacenado: "
            android:textColor="@color/cocoa"
            android:textSize="15sp"
            android:textStyle="italic"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/imgPortadaItem" />

        <TextView
            android:id="@+id/tvshelflist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10sp"
            android:text="Ninguna "
            android:textColor="@color/cocoa"
            android:textSize="15sp"
            android:textStyle="italic"
            android:fontFamily="serif"
            app:layout_constraintBottom_toBottomOf="@+id/tvGenerosItem"
            app:layout_constraintStart_toEndOf="@+id/tvGenerosItem"
            app:layout_constraintTop_toTopOf="@+id/tvGenerosItem" />

        <ImageView
            android:id="@+id/ivEditbook"
            android:layout_width="40sp"
            android:layout_height="40sp"
            android:layout_marginEnd="50sp"
            app:layout_constraintBottom_toBottomOf="@+id/linearLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/linearLayout"
            app:srcCompat="@drawable/editicon" />

        <ImageView
            android:id="@+id/ivAddshelf"
            android:layout_width="40sp"
            android:layout_height="40sp"
            app:layout_constraintBottom_toBottomOf="@+id/linearLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/ivEditbook"
            app:layout_constraintTop_toTopOf="@+id/linearLayout"
            app:srcCompat="@drawable/addpost" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>