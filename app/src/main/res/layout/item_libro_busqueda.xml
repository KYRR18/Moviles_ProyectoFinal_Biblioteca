<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/khaki"
    app:strokeWidth="1dp"
    app:strokeColor="@color/camel">

    <RelativeLayout
        android:id="@+id/layoutLibro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgPortadaItem"
            android:layout_width="60dp"
            android:layout_height="90dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:scaleType="centerCrop"
            android:background="@color/camel"
            app:shapeAppearanceOverlay="@style/RoundedImageView" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/imgPortadaItem"
            android:layout_marginStart="16dp"
            android:layout_toStartOf="@id/tvGenerosItem"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTituloItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Título"
                android:textColor="@color/espresso"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAutorItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Autor"
                android:textColor="@color/cocoa"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvGenerosItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignBottom="@id/imgPortadaItem"
            android:text="Géneros"
            android:textColor="@color/cocoa"
            android:textSize="15sp"
            android:fontFamily="serif"
            android:textStyle="italic" />

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>